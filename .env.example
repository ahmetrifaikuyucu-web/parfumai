# ParfumAI — Çevre Değişkenleri
# Kullanmak için: bu dosyayı .env olarak kopyalayın ve değerleri girin

# AI Servis Ayarları
# ------------------
# Sağlayıcı: "google" (Gemini) veya "openrouter"
AI_PROVIDER=google

# Google Gemini API Key (ücretsiz): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter API Key (opsiyonel): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Uygulama Ayarları
# ------------------
# Varsayılan: admin / admin123 — üretimde değiştirin!
ADMIN_PASSWORD=admin123
FLASK_DEBUG=0
# Üretimde rastgele uzun bir değer kullanın
SECRET_KEY=bU-asama-gecici-anahtar-produksiyonda-degistir
